# ============================================================
#  CustomerPulse — Environment Variables Template
#  Copy this file and rename it — DO NOT commit real credentials
# ============================================================

# ---- BACKEND  (copy to: backend/.env) ----------------------

# Local SQLite (works out of the box, no setup needed)
DATABASE_URL=sqlite:///./customer_pulse.db

# Production PostgreSQL — replace with your Neon / Supabase connection string
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

DEBUG=True
PORT=8000
HOST=0.0.0.0


# ---- FRONTEND  (copy to: frontend/.env.local) --------------

# Local FastAPI server
NEXT_PUBLIC_API_URL=http://localhost:8000

# Production Render backend
# NEXT_PUBLIC_API_URL=https://your-service-name.onrender.com
